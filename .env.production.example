APP_ENV=production
PUBLIC_BASE_URL=https://www.micetro.org

# Comma-separated; do not use "*" in production.
CORS_ORIGINS=https://www.micetro.org,https://micetro.org
TRUSTED_HOSTS=www.micetro.org,micetro.org

# Session and cookie security
SESSION_IDLE_MINUTES=10
COOKIE_SECURE=1
COOKIE_SAMESITE=none

# App admin bootstrap
APP_ADMIN_USER=CreaTRO
APP_ADMIN_PASS=CHANGE_ME

# Infra
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/transfer_db
REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/app/storage/uploads
